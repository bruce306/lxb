#
# File: Makefile.linux
#
#		Makefile used to make lxb for the Linux O/S
#		Modified for Ubunto and new disposition of X 12/20/17
#
#---------------------------------------------------------------------------

#  change these to point to the build direcories for lxb and misc X source
#
HOME = /home/lxb
XDIR = /home/lxb/lxb/oldX11

CC=gcc
CDEBUGFLAGS = -g -ggdb

CFLAGS = $(CDEBUGFLAGS) $(INCLUDES) $(DEFINES)
LDFLAGS = -o

DEFINES =

INCLUDES = -I../include -I$(HOME)/lxb/oldX11/include -I/usr/include/x86_64-linux-gnu -I/usr/include/x86_64-linux-gnu/gnu -I/usr/lib/gcc/x86_64-linux-gnu/5/include

#
#  use my built and installed Motif library - Ubuntu v16 12/23/17
#
#    -the libs exist but not the header files for all X11
#    - built and installed the latest Motif libs from Sourceforge
#    - did a make install on the MOTIF src dir; installed in /usr/lib
#    - don't know why but the Motif Library has to be included first or
#      you get a bad window error
#
#XLIBS = -lXm -lX11 -lXmu -lXt -lXaw

XLIBS = -lXm -lX11 -lXt -lXaw

LIBS = $(XLIBS)

#---------------------------------------------------------------------------
OBJS = about.o cascade.o cfunctions.o children.o cmenu.o \
	code.o code_gui.o code_hdr.o code_special.o code_util.o  code_xdefs.o \
	color.o create_composite.o create_simple.o cscrolled.o cvt_resvalue.o \
	data.o delete.o diag.o dialogs.o dump.o end_program.o fonts.o forms.o \
	get_resnames.o get_resvalue.o id_resource.o instant.o lxb.o menu.o \
	menubar.o menushell.o mhandlers.o misc.o open.o play.o populate.o 	\
	pulldown.o recreate.o recres.o save.o select.o selected.o set_resvalue.o \
	show_options.o show_res.o special.o top.o translations.o util.o \
	ResourceEd.o Wtree.o TextObject.o Pallet.o TopShell.o CallbackEd.o callbacks.o
#---------------------------------------------------------------------------

lxb: $(OBJS) 
	$(CC) $(LDFLAGS) lxb $(OBJS) $(LIBS) 

relink:
	rm -f lxb
	$(CC) $(LDFLAGS) lxb $(OBJS) $(LIBS)

all: clean depend lxb

#all: clean lxb

clean:
	rm -f lxb *.o *.a 

ctags:	
	ctags *.c

depend:	
	makedepend $(INCLUDES) $(DEFINES) *.c


